# KG Microbe KB MCP - Environment Configuration Example
# Copy this file to .env and modify as needed
# Then run: docker-compose up -d

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Port to expose (on host machine)
# Internal port is always 8080, this maps external port
PORT=8031

# Host to bind to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Transport type for MCP communication protocol
# Options:
#   - sse      : Server-Sent Events (HTTP streaming, default)
#                 Best for: Web clients, VS Code extensions, Browser-based
#                 Pros: Real-time streaming, event-based, works over HTTP
#                 Cons: One-way communication (server → client)
#   
#   - stdio    : Standard Input/Output (local process communication)
#                 Best for: Local CLI tools, same-machine connections
#                 Pros: No network overhead, simple bidirectional
#                 Cons: Local only, requires direct process spawning
#   
#   - http     : Full HTTP REST API
#                 Best for: General purpose HTTP clients, curl, Postman
#                 Pros: Standard HTTP, works with any HTTP client
#                 Cons: May have latency compared to stdio
#
# Default recommendation: sse (for shared server use case)
TRANSPORT=sse

# ==========================================
# KNOWLEDGE BASE CONFIGURATION
# ==========================================

# Path to pre-built embeddings (tar.gz or directory)
EMBEDDINGS_PATH=./kg-schema-docs.tar.gz

# Optional: Configuration file for knowledge base
CONFIG_FILE=kg-m-based-config.yml

# ==========================================
# DEBUGGING & LOGGING
# ==========================================

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Enable debug mode (more verbose output)
DEBUG=false

# ==========================================
# HUGGING FACE MODEL CACHING (Optional)
# ==========================================

# Directory to cache Hugging Face models
# HF_CACHE_DIR=/root/.cache/huggingface/hub

# Work offline mode (if models are pre-cached)
# TRANSFORMERS_OFFLINE=false

# ==========================================
# TXTAI PERFORMANCE TUNING (Optional/Advanced)
# ==========================================

# Batch size for embedding operations (higher = more RAM, faster)
# TXTAI_BATCH_SIZE=32

# Embedding model to use
# TXTAI_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Enable GPU support (if available)
# TXTAI_GPU=false

# Maximum content length
# TXTAI_MAX_CONTENT_LENGTH=10000
